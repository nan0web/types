{
	"$schema": "vscode://schemas/language-configuration",
	"comments": {
		"lineComment": "#"
	},
	"brackets": [
		["{", "}"],
		["[", "]"]
	],
	"autoClosingPairs": [
		{ "open": "{", "close": "}" },
		{ "open": "[", "close": "]" },
		{ "open": "\"", "close": "\"" }
	],
	"surroundingPairs": [
		{ "open": "{", "close": "}" },
		{ "open": "[", "close": "]" },
		{ "open": "\"", "close": "\"" }
	],
	"indentationRules": {
		"increaseIndentPattern": "^\\s*\\S+:\\s*$",
		"decreaseIndentPattern": "^\\s*$"
	},
	"folding": {
		"indentationBased": true
	}
}
